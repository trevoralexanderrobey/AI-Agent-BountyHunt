{
  "name": "openclaw-bridge-service",
  "description": "Local job queue + tool-runner bridge for dispatching security/bounty tasks to OpenClaw.",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.1",
    "dockerode": "4.0.9",
    "redis": "4.7.0",
    "tar-stream": "3.1.7"
  },
  "devDependencies": {
    "@types/node": "22.14.1",
    "tsx": "4.20.5",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  },
  "scripts": {
    "supervisor:registry": "tsx scripts/export-supervisor-registry.ts",
    "supervisor:registry:check": "tsx scripts/check-supervisor-registry.ts",
    "bridge:build": "npm run supervisor:registry && npm run supervisor:registry:check && tsc -p tsconfig.bridge.json",
    "bridge:control": "./scripts/bridge-control.sh",
    "bridge:start": "./scripts/bridge-control.sh start",
    "bridge:stop": "./scripts/bridge-control.sh stop",
    "bridge:restart": "./scripts/bridge-control.sh restart",
    "bridge:status": "./scripts/bridge-control.sh status",
    "bridge:logs": "./scripts/bridge-control.sh logs",
    "bridge:health": "./scripts/bridge-control.sh health",
    "bridge:test": "vitest run bridge/tests",
    "execution:test": "npm run bridge:build && node --test tests/execution/*.test.js",
    "workload:verify": "npm run bridge:build && node dist/scripts/verify-workload-manifest.js",
    "phase24:validate": "npm run bridge:build && node dist/scripts/validate-phase24.js",
    "ci:phase24-governance": "npm run workload:verify && npm run phase24:validate"
  },
  "version": "0.1.0"
}
