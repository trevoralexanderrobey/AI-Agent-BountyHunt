{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node 20",
  "include": ["bridge/**/*"],
  "compilerOptions": {
    "lib": ["es2022"],
    "module": "commonjs",
    "target": "es2022",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "types": ["node", "vitest/globals"]
  }
}
